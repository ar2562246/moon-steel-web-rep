# =============================================================================
# Moon Steel — environment variables
# Copy to `.env.local` (root) and/or `artifacts/moonsteel/.env.local` as needed.
# =============================================================================

# --- Next.js site (artifacts/moonsteel) --------------------------------------

# Public site URL used for metadata, sitemap, and robots.txt
# Production (Vercel): set to your live domain, e.g. https://moon-steel-web-rep.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — required for admin login and content management
# Find these in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only — contact form inserts (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Contact form notifications (optional — Resend)
CONTACT_NOTIFICATION_EMAIL=info@moonsteelfab.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Moon Steel <noreply@yourdomain.com>

# --- API server & database (optional, for full-stack local dev) ----------------

# PostgreSQL connection string (Drizzle ORM + api-server)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moonsteel

# API server port (required when running @workspace/api-server)
PORT=8080

# Logging level for api-server: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
